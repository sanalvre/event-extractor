# Copy to .env and fill in. Never commit .env.

# Required for timeline synthesis (unless using --dry-run for LLM only).
OPENROUTER_API_KEY=

# Optional OpenAI-compatible base URL (default: https://openrouter.ai/api/v1).
OPENROUTER_BASE_URL=

# Example cost-efficient ids: deepseek/deepseek-chat, anthropic/claude-3.5-haiku
OPENROUTER_MODEL=

# LLM extraction temperature (lower = less paraphrase; typical 0.0–0.1)
ETE_OPENROUTER_TEMPERATURE=0.05

# Speech-to-text: faster_whisper (default, real audio) or stub (fake lines — tests only).
ETE_TRANSCRIBER=faster_whisper

# faster-whisper model: tiny | base | small | medium | large-v3 (larger = often fewer word errors, slower)
ETE_WHISPER_MODEL_SIZE=small

# 1 = faster decode; increase slightly for quality
ETE_WHISPER_BEAM_SIZE=1

# Skip silence with VAD (usually faster on speech-heavy video)
ETE_WHISPER_VAD=true

# Per-word timestamps (slightly more compute; helps precise time anchoring)
ETE_WHISPER_WORD_TIMESTAMPS=false

# none | pyannote — optional speaker diarization (pip install -e ".[diarize]", HF_TOKEN, accept model terms)
ETE_DIARIZATION=none

# Hugging Face token for pyannote models (https://huggingface.co/settings/tokens)
HF_TOKEN=

# Drop timeline events whose evidence is not found verbatim in the transcript (after whitespace norm)
ETE_VALIDATE_EVIDENCE=true

# Dev: force fake transcript + optional stub path
ETE_USE_STUB=0
